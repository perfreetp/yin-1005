<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.digitaltwin.pipeline.mapper.inspection.WorkOrderMapper">

    <resultMap id="WorkOrderMap" type="com.digitaltwin.pipeline.entity.inspection.WorkOrder">
        <id column="id" property="id"/>
        <result column="order_code" property="orderCode"/>
        <result column="title" property="title"/>
        <result column="order_type" property="orderType"/>
        <result column="order_source" property="orderSource"/>
        <result column="urgency" property="urgency"/>
        <result column="description" property="description"/>
        <result column="lng" property="lng"/>
        <result column="lat" property="lat"/>
        <result column="location" property="location"/>
        <result column="pipeline_id" property="pipelineId"/>
        <result column="pipeline_code" property="pipelineCode"/>
        <result column="manhole_id" property="manholeId"/>
        <result column="valve_id" property="valveId"/>
        <result column="area_code" property="areaCode"/>
        <result column="area_name" property="areaName"/>
        <result column="alarm_id" property="alarmId"/>
        <result column="hazard_id" property="hazardId"/>
        <result column="defect_id" property="defectId"/>
        <result column="application_id" property="applicationId"/>
        <result column="creator" property="creator"/>
        <result column="create_order_time" property="createOrderTime"/>
        <result column="dispatch_time" property="dispatchTime"/>
        <result column="dispatcher" property="dispatcher"/>
        <result column="undertake_dept" property="undertakeDept"/>
        <result column="undertaker" property="undertaker"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="expect_complete_time" property="expectCompleteTime"/>
        <result column="actual_start_time" property="actualStartTime"/>
        <result column="actual_complete_time" property="actualCompleteTime"/>
        <result column="used_hours" property="usedHours"/>
        <result column="materials" property="materials"/>
        <result column="labor_cost" property="laborCost"/>
        <result column="construction_workers" property="constructionWorkers"/>
        <result column="disposal_plan" property="disposalPlan"/>
        <result column="disposal_process" property="disposalProcess"/>
        <result column="disposal_result" property="disposalResult"/>
        <result column="acceptor" property="acceptor"/>
        <result column="accept_time" property="acceptTime"/>
        <result column="accept_opinion" property="acceptOpinion"/>
        <result column="accept_qualified" property="acceptQualified"/>
        <result column="before_images" property="beforeImages"/>
        <result column="during_images" property="duringImages"/>
        <result column="after_images" property="afterImages"/>
        <result column="status" property="status"/>
        <result column="current_node" property="currentNode"/>
        <result column="progress" property="progress"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectPageList" resultMap="WorkOrderMap">
        SELECT * FROM work_order
        <where>
            deleted = 0
            <if test="orderType != null">
                AND order_type = #{orderType}
            </if>
            <if test="orderSource != null">
                AND order_source = #{orderSource}
            </if>
            <if test="urgency != null">
                AND urgency = #{urgency}
            </if>
            <if test="areaCode != null and areaCode != ''">
                AND area_code LIKE CONCAT(#{areaCode}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="undertaker != null and undertaker != ''">
                AND undertaker LIKE CONCAT('%', #{undertaker}, '%')
            </if>
            <if test="keyword != null and keyword != ''">
                AND (order_code LIKE CONCAT('%', #{keyword}, '%')
                OR title LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY urgency DESC, id DESC
    </select>

</mapper>
