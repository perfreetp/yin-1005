<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.digitaltwin.pipeline.mapper.asset.PipelineMapper">

    <resultMap id="PipelineMap" type="com.digitaltwin.pipeline.entity.asset.Pipeline">
        <id column="id" property="id"/>
        <result column="pipeline_code" property="pipelineCode"/>
        <result column="pipeline_name" property="pipelineName"/>
        <result column="pipeline_type" property="pipelineType"/>
        <result column="material" property="material"/>
        <result column="diameter" property="diameter"/>
        <result column="length" property="length"/>
        <result column="buried_depth" property="buriedDepth"/>
        <result column="start_node_code" property="startNodeCode"/>
        <result column="end_node_code" property="endNodeCode"/>
        <result column="start_lng" property="startLng"/>
        <result column="start_lat" property="startLat"/>
        <result column="end_lng" property="endLng"/>
        <result column="end_lat" property="endLat"/>
        <result column="geometry" property="geometry"/>
        <result column="area_code" property="areaCode"/>
        <result column="area_name" property="areaName"/>
        <result column="road_name" property="roadName"/>
        <result column="build_year" property="buildYear"/>
        <result column="owner_unit" property="ownerUnit"/>
        <result column="maintenance_unit" property="maintenanceUnit"/>
        <result column="status" property="status"/>
        <result column="pressure_level" property="pressureLevel"/>
        <result column="section_info" property="sectionInfo"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectPageList" resultMap="PipelineMap">
        SELECT * FROM pipeline
        <where>
            deleted = 0
            <if test="pipelineType != null">
                AND pipeline_type = #{pipelineType}
            </if>
            <if test="areaCode != null and areaCode != ''">
                AND area_code LIKE CONCAT(#{areaCode}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (pipeline_code LIKE CONCAT('%', #{keyword}, '%')
                OR pipeline_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectByAreaAndType" resultMap="PipelineMap">
        SELECT * FROM pipeline
        <where>
            deleted = 0
            <if test="areaCode != null and areaCode != ''">
                AND area_code LIKE CONCAT(#{areaCode}, '%')
            </if>
            <if test="pipelineType != null">
                AND pipeline_type = #{pipelineType}
            </if>
        </where>
        ORDER BY id
    </select>

    <select id="selectConnectedPipelines" resultMap="PipelineMap">
        SELECT * FROM pipeline
        WHERE deleted = 0
        AND (start_node_code = #{nodeCode} OR end_node_code = #{nodeCode})
    </select>

</mapper>
