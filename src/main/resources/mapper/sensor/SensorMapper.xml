<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.digitaltwin.pipeline.mapper.sensor.SensorMapper">

    <resultMap id="SensorMap" type="com.digitaltwin.pipeline.entity.sensor.Sensor">
        <id column="id" property="id"/>
        <result column="sensor_code" property="sensorCode"/>
        <result column="sensor_name" property="sensorName"/>
        <result column="sensor_type" property="sensorType"/>
        <result column="model" property="model"/>
        <result column="manufacturer" property="manufacturer"/>
        <result column="lng" property="lng"/>
        <result column="lat" property="lat"/>
        <result column="install_location" property="installLocation"/>
        <result column="pipeline_id" property="pipelineId"/>
        <result column="pipeline_code" property="pipelineCode"/>
        <result column="area_code" property="areaCode"/>
        <result column="area_name" property="areaName"/>
        <result column="range_min" property="rangeMin"/>
        <result column="range_max" property="rangeMax"/>
        <result column="unit" property="unit"/>
        <result column="alarm_upper" property="alarmUpper"/>
        <result column="alarm_lower" property="alarmLower"/>
        <result column="collect_interval" property="collectInterval"/>
        <result column="install_date" property="installDate"/>
        <result column="maintenance_unit" property="maintenanceUnit"/>
        <result column="status" property="status"/>
        <result column="last_value" property="lastValue"/>
        <result column="last_read_time" property="lastReadTime"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectPageList" resultMap="SensorMap">
        SELECT * FROM pipeline_sensor
        <where>
            deleted = 0
            <if test="sensorType != null">
                AND sensor_type = #{sensorType}
            </if>
            <if test="areaCode != null and areaCode != ''">
                AND area_code LIKE CONCAT(#{areaCode}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (sensor_code LIKE CONCAT('%', #{keyword}, '%')
                OR sensor_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectByAreaAndType" resultMap="SensorMap">
        SELECT * FROM pipeline_sensor
        <where>
            deleted = 0
            <if test="areaCode != null and areaCode != ''">
                AND area_code LIKE CONCAT(#{areaCode}, '%')
            </if>
            <if test="sensorType != null">
                AND sensor_type = #{sensorType}
            </if>
        </where>
        ORDER BY id
    </select>

</mapper>
